# ==============================================================================
# Copy this to .env.local and configure with your values
# ==============================================================================

# Supabase Database
DB_ENVIRONMENT=development
SUPABASE_URL_DEVELOPMENT=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY_DEVELOPMENT=YOUR_ANON_KEY

# Redis Caching (optional)
# REDIS_URL=redis://localhost:6379

# LLM Provider for Reflections
# Options: 'ollama' (local) or 'openrouter' (API)
LLM_PROVIDER=ollama

# Ollama Configuration (local inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=60000
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=500
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40

# OpenRouter Configuration (API-based)
# Get free API key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_TIMEOUT=60000
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=1500
OPENROUTER_TOP_P=0.9

